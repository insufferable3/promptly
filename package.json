{
  "name": "promptly-desktop",
  "version": "0.1.0",
  "description": "Promptly desktop AI productivity companion",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --strictPort --open",
    "backend": "cd backend && .venv/bin/uvicorn main:app --port 8000",
    "desktop": "concurrently -k \"vite --strictPort --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.promptly.desktop",
    "productName": "Promptly",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "latest",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "framer-motion": "^12.40.0",
    "react": "latest",
    "react-dom": "latest",
    "tailwindcss": "^4.3.1",
    "vite": "latest",
    "wait-on": "^9.0.10"
  }
}
